# Postgres + Redis are provisioned via docker-compose.yml, remapped to avoid
# colliding with other local services (see docs/architecture.md).
DATABASE_URL=postgresql+asyncpg://codemind:codemind@localhost:5433/codemind
REDIS_URL=redis://localhost:6380/0

JWT_SECRET=dev-secret-change-me-in-production-32bytes-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
SESSION_COOKIE_NAME=codemind_session

WEB_ORIGIN=http://localhost:3000

# apps/web
NEXT_PUBLIC_API_URL=http://localhost:8010
